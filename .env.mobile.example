# 모바일 릴리스 빌드용 (복사: cp .env.mobile.example .env.mobile)
# scripts/build-mobile.sh 는 BOOKFOLIO_API_BASE_URL 이 셸에 없을 때만 이 파일을 읽습니다.
BOOKFOLIO_API_BASE_URL=https://your-app.vercel.app
# 웹과 동일한 OAuth「웹 애플리케이션」클라이언트 ID (apps/web .env 의 AUTH_GOOGLE_ID). 서버가 ID 토큰 aud 로 검증합니다.
# GOOGLE_AUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
