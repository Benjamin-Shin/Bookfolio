{
  "name": "bookfolio",
  "private": true,
  "version": "1.0.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "pnpm --filter @bookfolio/web run dev",
    "build:web": "pnpm --filter @bookfolio/web run build",
    "lint:web": "pnpm --filter @bookfolio/web run lint",
    "typecheck:web": "pnpm --filter @bookfolio/web run typecheck",
    "vercel:preview": "bash scripts/deploy-vercel.sh",
    "vercel:prod": "bash scripts/deploy-vercel.sh prod",
    "build:mobile": "bash scripts/build-mobile.sh apk-split",
    "build:mobile:apk-split": "bash scripts/build-mobile.sh apk-split",
    "build:mobile:apk": "bash scripts/build-mobile.sh apk",
    "build:mobile:appbundle": "bash scripts/build-mobile.sh appbundle",
    "build:mobile:ipa": "bash scripts/build-mobile.sh ipa",
    "build:mobile:ios": "bash scripts/build-mobile.sh ios",
    "gen:mobile-app-icon": "npx --yes sharp-cli resize 1024 1024 --input apps/web/public/assets/bookfolio_b_favicon.svg --output apps/mobile/assets/brand/app_icon.png && cd apps/mobile && dart run flutter_launcher_icons",
    "db-push": "npx supabase@latest db push"
  }
}
