NEXT_PUBLIC_APP_URL=http://localhost:3000
# Android APK 등 다운로드 URL (비우면 헤더에 아이콘 숨김)
# NEXT_PUBLIC_APP_DOWNLOAD_URL=https://example.com/app-release.apk

# NextAuth (필수: AUTH_SECRET, Google 로그인 시 AUTH_GOOGLE_*)
# AUTH_SECRET: openssl rand -base64 32
AUTH_SECRET=your-auth-secret
AUTH_GOOGLE_ID=your-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=GOCSPX-your-client-secret
# 모바일 Google 로그인: ID 토큰 aud 가 웹 클라이언트만이면 비워도 됨(AUTH_GOOGLE_ID 로 검증).
# Android 전용 클라이언트 ID만 쓰는 경우 콤마로 추가 (예: xxx.apps.googleusercontent.com,yyy.apps.googleusercontent.com)
# AUTH_GOOGLE_MOBILE_AUDIENCES=

# Vercel: Project → Settings → Environment Variables 에 동일 키 추가 (Preview/Production + Build에 포함)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
BOOK_METADATA_PROVIDER=openlibrary
# ISBN 조회 폴백: 네이버 책검색 → 국립중앙도서관 (값이 있는 제공자만 위 순서로 시도)
NL_API_CERT_KEY=your-nl-open-api-cert-key
NAVER_API_CLIENT_ID=your-naver-client-id
NAVER_API_CLIENT_SECRET=your-naver-client-secret

# Cloudinary (도서 표지 업로드 — 서버 전용, NEXT_PUBLIC 로 두지 마세요)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# 알라딘 TTB ItemList 전체 요청 URL (ttbkey·QueryType·output=xml|json 등 포함, 서버 전용 — NEXT_PUBLIC 아님)
# 예: QueryType=Bestseller, ItemNewAll … — https://www.aladin.co.kr/ttb/apiguide.aspx
# ALADIN_BESTSELLER_API_BASE_URL=
# 초이스 신간 등 별도 ItemList URL (베스트셀러와 다른 QueryType·카테고리 지정 시)
# ALADIN_ITEMNEW_API_BASE_URL=

# 첫 관리자: 마이그레이션 후 Supabase SQL 예시
# update public.app_users set role = 'ADMIN' where lower(email) = lower('you@example.com');
