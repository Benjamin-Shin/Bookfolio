NEXT_PUBLIC_APP_URL=http://localhost:3000
# Android APK 등 다운로드 URL (비우면 헤더에 아이콘 숨김)
# NEXT_PUBLIC_APP_DOWNLOAD_URL=https://example.com/app-release.apk

# NextAuth (필수: AUTH_SECRET, Google 로그인 시 AUTH_GOOGLE_*)
# AUTH_SECRET: openssl rand -base64 32
AUTH_SECRET=your-auth-secret
AUTH_GOOGLE_ID=your-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=GOCSPX-your-client-secret

# Vercel: Project → Settings → Environment Variables 에 동일 키 추가 (Preview/Production + Build에 포함)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
BOOK_METADATA_PROVIDER=openlibrary
# ISBN 조회 폴백: 국립중앙도서관 → 네이버 책검색 → Google Books (값이 있는 제공자만 위 순서로 시도)
NL_API_CERT_KEY=your-nl-open-api-cert-key
NAVER_API_CLIENT_ID=your-naver-client-id
NAVER_API_CLIENT_SECRET=your-naver-client-secret
GOOGLE_BOOKS_API_KEY=your-google-books-api-key

# 첫 관리자: 마이그레이션 후 Supabase SQL 예시
# update public.app_users set role = 'ADMIN' where lower(email) = lower('you@example.com');
